# Ultimate Dashboard - environment variables
# GitHub:     https://github.com/Marcel-Balk/UltimateDashboard
# Docker Hub: https://hub.docker.com/r/extremedatacenter/ultimatedashboard
#
# Copy this file to .env and fill in your values.
# !! Never commit .env to version control !!

# ─────────────────────────────────────────────────────────────
# Cloudflare DNS API token (for Let's Encrypt DNS-01 challenge)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone → DNS → Edit
# ─────────────────────────────────────────────────────────────
CF_DNS_API_TOKEN=your_cloudflare_dns_api_token_here

# ACME contact email (Let's Encrypt notifications)
ACME_EMAIL=you@example.com

# ─────────────────────────────────────────────────────────────
# APP_DOMAIN - the domain your dashboard is served on.
# Make sure the DNS A record for this domain points to this server.
# Change this value and run "docker compose up -d" to redeploy
# on a different domain - no rebuild required.
# ─────────────────────────────────────────────────────────────
APP_DOMAIN=dashboard.yourdomain.com
